# ============================================
# Amadeus - 命运石之门 AI 助手配置
# 复制此文件为 .env 并填入你的 API Key
# ============================================

# --- LLM 提供商: deepseek | qwen ---
LLM_PROVIDER=deepseek

# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=sk-your-api-key-here

# DeepSeek API 地址（默认即可）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 模型选择：deepseek-chat (V3) 或 deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 API Key（从 https://dashscope.console.aliyun.com/apiKey 获取）
QWEN_API_KEY=sk-your-qwen-key-here

# 通义千问 API 地址（默认即可）
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型选择：qwen3.7-plus (推荐) / qwen3.7-max
QWEN_MODEL=qwen3.7-plus

# GPT-SoVITS TTS API 地址
SOVITS_API_URL=http://127.0.0.1:9880

# 服务端口
SERVER_PORT=8000

# 是否开启调试模式
DEBUG=true
